# Normalize line endings
* text=auto

# PowerShell scripts: keep LF (works fine in pwsh, avoids noisy diffs)
*.ps1 text eol=lf
*.psm1 text eol=lf
*.psd1 text eol=lf

# SQL + Python: LF
*.sql text eol=lf
*.py  text eol=lf

# YAML / JSON: LF
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf

# Markdown
*.md text eol=lf
